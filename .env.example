# server | desktop | test
DIANGAO_MODE=desktop
HOST=127.0.0.1
PORT=3100
PUBLIC_BASE_URL=http://127.0.0.1:3100
DB_PATH=./data/diangao.db

# 生产环境必须替换为至少 32 字节的随机字符串。
APP_SECRET=replace-with-a-random-secret-at-least-32-bytes

# 微信小程序登录。仅服务器部署需要，桌面本地模式不需要。
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 加密在线备份使用独立密钥；不要与 APP_SECRET 相同。
BACKUP_SECRET=replace-with-an-independent-backup-secret
BACKUP_DIR=./backups

# 可选：PDF 中文字体。未设置时自动查找微软雅黑或 Noto Sans CJK。
PDF_FONT_PATH=

# 生产环境允许的跨域来源，逗号分隔；同源部署可留空。
CORS_ORIGINS=
