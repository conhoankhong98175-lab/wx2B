{
  "name": "diangao-quote-assistant",
  "version": "1.0.0",
  "private": true,
  "description": "店告：本地优先的微信报价成交助手",
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "npm run clean && npm run build:web && npm run build:server",
    "build:web": "vite build --config web/vite.config.ts",
    "build:server": "node scripts/build-server.mjs",
    "build:windows": "powershell -ExecutionPolicy Bypass -File scripts/build-windows.ps1",
    "package:windows": "node scripts/package-windows.mjs",
    "clean": "node scripts/clean.mjs",
    "start": "node dist/server/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "backup": "node scripts/backup.mjs",
    "restore": "node scripts/restore.mjs",
    "notices": "node scripts/generate-notices.mjs",
    "wechat:configure": "node scripts/configure-wechat.mjs",
    "wechat:preflight": "node scripts/wechat-preflight.mjs",
    "wechat:login": "node scripts/wechat-devtools.mjs login",
    "wechat:preview": "node scripts/wechat-devtools.mjs preview",
    "wechat:upload": "node scripts/wechat-devtools.mjs upload",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.7",
    "@hono/zod-validator": "^0.7.6",
    "@pdf-lib/fontkit": "^1.1.1",
    "decimal.js": "^10.6.0",
    "hono": "^4.10.7",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@electron/asar": "4.2.0",
    "@electron/packager": "20.0.2",
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.14",
    "concurrently": "^9.2.1",
    "electron": "43.1.1",
    "esbuild": "0.28.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^27.2.0",
    "prettier": "^3.7.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  }
}
