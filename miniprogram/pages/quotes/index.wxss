.filters {
  display: grid;
  grid-template-columns: 1fr 210rpx;
  gap: 14rpx;
  margin-bottom: 24rpx;
}
.quote-list {
  display: grid;
  gap: 18rpx;
}
.quote-card {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 26rpx;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(25, 52, 45, 0.05);
}
.quote-top,
.quote-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}
.quote-top > text:first-child,
.project,
.quote-bottom text {
  color: #75807d;
  font-size: 23rpx;
}
.quote-card > strong {
  margin-top: 4rpx;
  font-size: 32rpx;
}
.floating-add {
  position: fixed;
  right: 30rpx;
  bottom: 150rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  color: #fff;
  background: #0b6b5f;
  font-size: 52rpx;
  line-height: 100rpx;
  box-shadow: 0 14rpx 34rpx rgba(11, 107, 95, 0.3);
}
