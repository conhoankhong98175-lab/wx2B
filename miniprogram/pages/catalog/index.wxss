.tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 18rpx;
}
.tabs button {
  flex: 1;
  color: #697471;
  background: transparent;
  font-size: 26rpx;
}
.tabs button.active {
  color: #0b6b5f;
  background: #dfece9;
}
.action-row {
  margin-bottom: 22rpx;
}
.item-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 16rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #fff;
}
.item-card > view {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 7rpx;
}
.item-card text {
  max-width: 360rpx;
  overflow: hidden;
  color: #75807d;
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.item-card .right {
  align-items: flex-end;
  text-align: right;
}
.drawer-mask {
  position: fixed;
  z-index: 100;
  inset: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(8, 27, 23, 0.48);
}
.category-list {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  margin-bottom: 20rpx;
}
.category-chip {
  display: flex;
  align-items: center;
  flex: none;
  padding: 4rpx 8rpx;
  border-radius: 14rpx;
  background: #edf3f0;
}
.category-chip button {
  margin: 0;
  padding: 8rpx 12rpx;
  background: transparent;
  font-size: 23rpx;
}
.category-chip switch {
  transform: scale(0.75);
}
.checkbox-row {
  display: block;
  padding: 10rpx 0;
  font-size: 24rpx;
}
.drawer {
  width: 100%;
  max-height: 90vh;
  overflow-y: auto;
  padding: 30rpx 28rpx calc(30rpx + env(safe-area-inset-bottom));
  border-radius: 30rpx 30rpx 0 0;
  background: #fff;
}
.drawer-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 26rpx;
  font-size: 34rpx;
}
.drawer-title button {
  margin: 0;
  padding: 0 18rpx;
  background: #edf1ee;
}
.two {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 20rpx 0;
}
