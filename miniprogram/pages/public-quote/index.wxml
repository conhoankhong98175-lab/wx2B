<view wx:if="{{loading}}" class="loading">正在打开报价…</view>
<view wx:elif="{{error}}" class="unavailable"><text class="strong">报价无法打开</text><text>{{error}}</text></view>
<view wx:elif="{{!available}}" class="unavailable"><text class="strong">{{unavailable.merchant.name || '报价单'}}</text><text>{{unavailable.message}}</text><text>{{unavailable.quoteNumber}} · V{{unavailable.version}}</text><button wx:if="{{unavailable.merchant.contactPhone}}" class="primary-button" bindtap="callMerchant">联系商家</button></view>
<view wx:else class="public-page">
  <view class="quote-sheet">
    <view class="merchant-head"><image wx:if="{{quote.merchant.logoUrl}}" src="{{quote.merchant.logoUrl}}" mode="aspectFill" /><view><text>报价单</text><text class="strong">{{quote.merchant.name}}</text></view><text class="status {{quote.state}}">{{stateLabel}}</text></view>
    <view wx:if="{{stateMessage}}" class="state-message {{quote.state}}">{{stateMessage}}</view>
    <view class="meta-grid"><view><text>报价编号</text><text class="strong">{{quote.quoteNumber}}</text></view><view><text>版本</text><text class="strong">V{{quote.version}}</text></view><view><text>客户</text><text class="strong">{{quote.customerName}}</text></view><view><text>有效至</text><text class="strong">{{quote.validUntil}} 23:59</text></view><view wx:if="{{quote.projectName}}" class="wide"><text>项目</text><text class="strong">{{quote.projectName}}</text></view><view class="wide"><text>交付周期</text><text class="strong">{{quote.deliveryPeriod || '双方另行确认'}}</text></view></view>
    <view class="section"><text class="section-title">报价明细</text><view wx:for="{{quote.calculation.lines}}" wx:key="id" class="quote-line"><view><text class="strong">{{index + 1}}. {{item.name}}</text><text class="strong">￥{{item.lineTotal}}</text></view><text>数量 {{item.quantity}} {{item.unit}}{{item.billableArea ? ' · 计费面积 ' + item.billableArea + '㎡' : ''}}</text><text wx:if="{{item.description}}">说明：{{item.description}}</text><view wx:for="{{item.addOns}}" wx:for-item="addon" wx:key="id" class="addon"><text>＋ {{addon.name}}</text><text>￥{{addon.amount}}</text></view></view><view wx:if="{{quote.calculation.orderAddOns.length}}" class="order-addons"><text class="section-title">整单附加费用</text><view wx:for="{{quote.calculation.orderAddOns}}" wx:for-item="addon" wx:key="id" class="addon"><text>{{addon.name}}</text><text>￥{{addon.amount}}</text></view></view></view>
    <view class="summary"><view><text>小计</text><text class="strong">￥{{quote.calculation.subtotal}}</text></view><view wx:if="{{quote.calculation.discountAmount !== '0.00'}}"><text>优惠</text><text class="strong">-￥{{quote.calculation.discountAmount}}</text></view><view wx:if="{{quote.calculation.manualAdjustment !== '0.00'}}"><text>手工调整</text><text class="strong">￥{{quote.calculation.manualAdjustment}}</text></view><view><text>税务模式</text><text class="strong">{{quote.calculation.taxMode === 'NONE' ? '不计税' : quote.calculation.taxMode === 'INCLUDED' ? '单价含税 · 税率 ' + quote.calculation.taxRate + '%' : '税费另计 · 税率 ' + quote.calculation.taxRate + '%'}}</text></view><view wx:if="{{quote.calculation.taxMode !== 'NONE'}}"><text>{{quote.calculation.taxMode === 'INCLUDED' ? '其中税额' : '税额'}}</text><text class="strong">￥{{quote.calculation.taxAmount}}</text></view><view wx:if="{{quote.calculation.roundingAdjustment !== '0.00'}}"><text>取整调整</text><text class="strong">￥{{quote.calculation.roundingAdjustment}}</text></view><view class="total"><text>报价总额</text><text class="strong">￥{{quote.calculation.total}}</text></view></view>
    <view wx:if="{{quote.notes || quote.terms}}" class="section terms"><text wx:if="{{quote.notes}}" class="section-title">备注</text><text wx:if="{{quote.notes}}">{{quote.notes}}</text><text wx:if="{{quote.terms}}" class="section-title gap">报价条款</text><text wx:if="{{quote.terms}}">{{quote.terms}}</text></view>
    <view class="contact"><text class="strong">{{quote.merchant.contactName || quote.merchant.name}}</text><text>{{quote.merchant.contactPhone}}{{quote.merchant.contactWechat ? ' · 微信 ' + quote.merchant.contactWechat : ''}}</text><text class="legal">接受报价用于确认当前价格与范围，不等同于付款或电子合同。</text></view>
  </view>
  <view class="export-row"><button class="secondary-button" bindtap="openPdf">PDF</button><button class="secondary-button" bindtap="saveImage">保存长图</button><button wx:if="{{quote.merchant.contactPhone}}" class="secondary-button" bindtap="callMerchant">电话</button></view>
  <canvas type="2d" id="quoteCanvas" class="quote-canvas" style="width:750px;height:{{canvasHeight}}px" />
  <view class="fixed-actions"><button class="secondary-button" bindtap="question">有问题</button><button class="secondary-button" disabled="{{quote.state !== 'ACTIVE'}}" bindtap="changeRequest">申请修改</button><button class="primary-button" disabled="{{quote.state !== 'ACTIVE'}}" bindtap="accept">{{quote.state === 'ACCEPTED' ? '已接受' : '接受报价'}}</button></view>
</view>
